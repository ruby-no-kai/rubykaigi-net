<%- overlay = node.dig(:wire, :interfaces, :overlay) -%>
[Match]
Name=<%= overlay.fetch(:name) %>

[Link]
RequiredForOnline=routable

[Network]
<%- if overlay[:dhcpv4] -%>
DHCP=ipv4
<%- end -%>
IPv6AcceptRA=yes
IPv4Forwarding=off
IPv6Forwarding=off

<%= node.fetch(:wire).fetch(:tunnels, {}).each_key.map { |name| "Tunnel=#{name}" }.join("\n") %>

[IPv6AcceptRA]
Token=<%= overlay.fetch(:ipv6_token) %>
DHCPv6Client=yes

[DHCPv6]
UseDNS=yes
<%- if overlay[:dhcpv4] -%>

[DHCPv4]
UseDNS=yes
UseRoutes=yes
<%- end -%>
